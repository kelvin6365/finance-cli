{
  "name": "finance-tracker",
  "version": "0.3.0",
  "type": "module",
  "private": true,
  "bin": {
    "finance": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build:macos-arm": "bun build --compile --target=bun-darwin-arm64 ./src/cli/index.ts --outfile dist/finance-macos-arm64",
    "build:macos-x64": "bun build --compile --target=bun-darwin-x64 ./src/cli/index.ts --outfile dist/finance-macos-x64",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./src/cli/index.ts --outfile dist/finance-linux-x64",
    "build:windows": "bun build --compile --target=bun-windows-x64 ./src/cli/index.ts --outfile dist/finance-windows-x64.exe",
    "build:all": "bun run build:macos-arm && bun run build:macos-x64 && bun run build:linux && bun run build:windows"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "react-devtools-core": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^7.0.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.5"
  }
}
